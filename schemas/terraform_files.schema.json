{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLM Direct Terraform Files Response",
  "type": "object",
  "required": ["files"],
  "properties": {
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "content"],
        "properties": {
          "path": {"type": "string"},
          "content": {"type": "string"}
        }
      }
    },
    "missing_fields": {
      "type": "array",
      "items": {}
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "risk_notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
