{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Huawei Cloud Terraform Requirements",
  "type": "object",
  "properties": {
    "project": {
      "type": "object",
      "properties": {
        "name": {"type": ["string", "null"]},
        "environment": {"type": ["string", "null"], "enum": ["dev", "stg", "prod", "test", null]},
        "region": {"type": ["string", "null"]},
        "provider_version": {"type": ["string", "null"]}
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "vpc_name": {"type": ["string", "null"]},
        "vpc_cidr": {"type": ["string", "null"]},
        "subnets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "logical_id": {"type": "string"},
              "operation": {"type": "string", "enum": ["upsert", "delete"]},
              "name": {"type": "string"},
              "cidr": {"type": "string"},
              "gateway_ip": {"type": ["string", "null"]},
              "availability_zone": {"type": ["string", "null"]}
            },
            "required": ["logical_id", "operation", "name", "cidr"]
          }
        }
      }
    },
    "security_groups": {"type": "array", "items": {"$ref": "#/$defs/resourceOperation"}},
    "ecs": {"type": "array", "items": {"$ref": "#/$defs/resourceOperation"}},
    "rds": {"type": "array", "items": {"$ref": "#/$defs/resourceOperation"}},
    "obs": {"type": "array", "items": {"$ref": "#/$defs/resourceOperation"}},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "resourceOperation": {
      "type": "object",
      "properties": {
        "logical_id": {"type": "string", "minLength": 1},
        "operation": {"type": "string", "enum": ["upsert", "delete"]}
      },
      "required": ["logical_id", "operation"],
      "additionalProperties": true
    }
  }
}
