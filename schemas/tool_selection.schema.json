{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Python Tool Selection Result",
  "type": "object",
  "required": ["route", "confidence", "reason", "parameters"],
  "properties": {
    "route": {
      "type": "string",
      "enum": ["terraform_flow", "python_tool", "clarify"]
    },
    "tool_name": {
      "type": ["string", "null"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason": {
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "missing_fields": {
      "type": "array"
    },
    "next_question": {
      "type": ["string", "null"]
    },
    "safety_notes": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
