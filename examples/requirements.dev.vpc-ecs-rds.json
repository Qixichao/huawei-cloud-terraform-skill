{
  "project": {
    "name": "demo-ai-platform",
    "environment": "dev",
    "region": "me-east-1",
    "provider_version": "~> 1.93"
  },
  "network": {
    "vpc_name": "demo-vpc",
    "vpc_cidr": "10.10.0.0/16",
    "subnets": [
      {
        "name": "app-subnet",
        "cidr": "10.10.1.0/24",
        "gateway_ip": "10.10.1.1",
        "availability_zone": "me-east-1a"
      },
      {
        "name": "db-subnet",
        "cidr": "10.10.2.0/24",
        "gateway_ip": "10.10.2.1",
        "availability_zone": "me-east-1b"
      }
    ]
  },
  "security_groups": [
    {
      "name": "app-sg",
      "description": "Application server security group",
      "rules": [
        {
          "direction": "ingress",
          "protocol": "tcp",
          "port": 8080,
          "remote_ip_prefix": "10.10.0.0/16"
        }
      ]
    },
    {
      "name": "db-sg",
      "description": "Database security group",
      "rules": [
        {
          "direction": "ingress",
          "protocol": "tcp",
          "port": 3306,
          "remote_ip_prefix": "10.10.1.0/24"
        }
      ]
    }
  ],
  "ecs": [
    {
      "name": "app-server-01",
      "count": 1,
      "image": "Ubuntu 22.04",
      "flavor": "s6.large.2",
      "subnet": "app-subnet",
      "security_group": "app-sg",
      "public_ip": false
    }
  ],
  "rds": [
    {
      "name": "app-mysql",
      "engine": "mysql",
      "version": "8.0",
      "flavor": "rds.mysql.n1.large.2",
      "storage_gb": 100,
      "ha_enabled": true,
      "subnet": "db-subnet",
      "security_group": "db-sg",
      "password_variable": "rds_password"
    }
  ],
  "obs": [],
  "notes": [
    "This example is for LLM Direct generation testing only. Verify provider fields before real deployment."
  ]
}
